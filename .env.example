# Copy this file to .env and fill only the providers you want to use.
# Never commit .env. It is ignored by .gitignore.

# Recommended primary teacher
TOGETHER_API_KEY=

# Recommended fallback / structured-output provider
FIREWORKS_API_KEY=

# Optional cheap gate / secondary judge
GEMINI_API_KEY=

# Optional fast fallback
CEREBRAS_API_KEY=

# Pipeline defaults
ANAS_PROVIDER=together
ANAS_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
ANAS_OUTPUT_DIR=output
